# Сырьё и технические входы разведки — не нужны дашборду (app.py читает
# только data/), регенерируются пайплайном локально. Не бэкапятся в GitHub.
raw/
magstat/
other_files/
test_spreadsheets/

# Локальные dev-инструменты (Claude Code preview), не часть проекта
.claude/

# Секреты (пароль дашборда, ключ сервисного аккаунта Google) — локальные
# копии для тестов, на Streamlit Cloud те же секреты вносятся отдельно через
# Settings → Secrets, тоже не в git.
.streamlit/secrets.toml
.streamlit/*.json

# Данные — раньше лежали в репозитории, теперь грузятся в приложение из
# приватного Google Drive (через сервисный аккаунт), репозиторий публичный.
data/

# Системное
.DS_Store
__pycache__/
*.pyc
